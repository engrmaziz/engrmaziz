{
  "openapi": "3.1.0",
  "info": {
    "title": "Enterprise Knowledge Platform API",
    "version": "1.0.0",
    "description": "API specification for querying the canonical professional knowledge base."
  },
  "paths": {
    "/projects": {
      "get": {
        "summary": "List all projects",
        "responses": {
          "200": {
            "description": "A list of projects.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "../schemas/project.json"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/projects/{id}": {
      "get": {
        "summary": "Get a specific project",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single project.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../schemas/project.json"
                }
              }
            }
          }
        }
      }
    }
  }
}
