{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.musharraf.tech/schemas/faq.json",
  "title": "FAQ",
  "description": "Schema for a frequently asked question.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "question": {
      "type": "string"
    },
    "answer": {
      "type": "string"
    },
    "intent_category": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "question",
    "answer"
  ],
  "additionalProperties": false
}