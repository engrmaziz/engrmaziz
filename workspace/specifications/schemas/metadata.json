{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.musharraf.tech/schemas/metadata.json",
  "title": "Metadata",
  "description": "Schema for system metadata.",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": [
    "version",
    "last_updated"
  ],
  "additionalProperties": false
}