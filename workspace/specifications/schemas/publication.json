{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.musharraf.tech/schemas/publication.json",
  "title": "Publication",
  "description": "Schema for written articles or papers.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "publisher": {
      "type": "string"
    },
    "date_published": {
      "type": "string",
      "format": "date"
    },
    "url": {
      "type": "string",
      "format": "uri"
    }
  },
  "required": [
    "id",
    "title",
    "date_published"
  ],
  "additionalProperties": false
}