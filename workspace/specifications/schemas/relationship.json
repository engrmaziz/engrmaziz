{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.musharraf.tech/schemas/relationship.json",
  "title": "Relationship",
  "description": "Schema for entity relationships.",
  "type": "object",
  "properties": {
    "source_id": {
      "type": "string"
    },
    "target_id": {
      "type": "string"
    },
    "edge_type": {
      "type": "string",
      "enum": [
        "USES",
        "CREATED",
        "WORKED_AT",
        "HAS_SKILL",
        "REQUIRES",
        "OPERATES_IN"
      ]
    }
  },
  "required": [
    "source_id",
    "target_id",
    "edge_type"
  ],
  "additionalProperties": false
}