{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.musharraf.tech/schemas/recruiter_summary.json",
  "title": "Recruiter Summary",
  "description": "Schema for ATS data.",
  "type": "object",
  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "target_roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "years_experience": {
      "type": "integer"
    },
    "highlight_metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "candidate_id",
    "target_roles"
  ],
  "additionalProperties": false
}